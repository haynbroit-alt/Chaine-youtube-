# Copier vers `.env` et renseigner les clés nécessaires.

# --- API ---
API_HOST=127.0.0.1
API_PORT=8000
# Origines CORS séparées par des virgules (ex: http://localhost:3000) ; vide = désactivé
CORS_ORIGINS=

# --- IMAP (optionnel) ---
IMAP_HOST=
IMAP_USER=
IMAP_PASSWORD=
IMAP_FOLDER=INBOX
IMAP_SSL=true
IMAP_LIMIT=25
# true = seulement les non lus
IMAP_UNSEEN_ONLY=false

# --- Webhook (optionnel, ex. Slack/Discord incoming) ---
WEBHOOK_URL=
WEBHOOK_TIMEOUT_S=15

# --- Rangement automatique lors du digest (optionnel) ---
ORGANIZE_FOLDER=
ORGANIZE_ON_DIGEST=false
