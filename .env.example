# Copier vers `.env` et renseigner les clés nécessaires.

# --- API ---
API_HOST=127.0.0.1
API_PORT=8000
# Origines CORS séparées par des virgules (ex: http://localhost:3000) ; vide = désactivé
CORS_ORIGINS=

# --- IMAP (optionnel) ---
IMAP_HOST=
IMAP_USER=
IMAP_PASSWORD=
IMAP_FOLDER=INBOX
IMAP_SSL=true
IMAP_LIMIT=25
# true = seulement les non lus
IMAP_UNSEEN_ONLY=false

# --- Webhook (optionnel, ex. Slack/Discord incoming) ---
WEBHOOK_URL=
WEBHOOK_TIMEOUT_S=15

# --- Rangement automatique lors du digest (optionnel) ---
ORGANIZE_FOLDER=
ORGANIZE_ON_DIGEST=false

# --- OpenAI (optionnel, IA distante) ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Ollama (optionnel, IA 100 % locale ou sur votre réseau — pas de clé nuagique) ---
OLLAMA_BASE_URL=
OLLAMA_MODEL=llama3.2:3b
OLLAMA_TIMEOUT_S=120

# --- YouTube (optionnel, déploiement cloud / Vercel) ---
# Proxy HTTP ou HTTPS pour les requêtes de sous-titres (youtube-transcript-api).
# Les IP de fournisseurs cloud sont souvent bloquées par YouTube : sans proxy résidentiel
# fiable, l’endpoint POST /youtube/summarize peut échouer depuis Vercel, AWS, etc.
YOUTUBE_PROXY_URL=

# --- Lien affiché sur la page d’accueil HTML de l’API (ex. Streamlit Cloud) ---
STREAMLIT_PUBLIC_URL=
